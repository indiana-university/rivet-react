{
  "ignore": [
    ".github/**",
    ".git/**",
    "./coverage/**",
    ".husky/**",
    "**/.*",
    "**/*.md",
    "build/**",
    "*.config.cjs",
    "*.config.js"
  ],
  "license": "license-header.txt",
  "licenseFormats": {
    "js|jsx|ts|tsx": {
      "prepend": "/*",
      "append": "*/"
    },
    "yml|yaml": {
      "eachLine": {
        "prepend": "# "
      }
    }
  },
  "trailingWhitespace": "TRIM"
}
